{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities: local SQLite, file dialogs, attachment storage, and HTTPS access restricted to AI provider APIs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    "opener:default",
    "dialog:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "fs:allow-read-file",
      "comment": "Users import lab files from anywhere, so reads are broad — but secret stores are denied so a webview compromise can't exfiltrate credentials.",
      "allow": [
        {
          "path": "**"
        }
      ],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.config/**" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/Library/Keychains/**" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.npmrc" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DOCUMENT/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "comment": "Copies a user-picked attachment into the app data dir; source can be anywhere except secret stores.",
      "allow": [
        {
          "path": "**"
        }
      ],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.config/**" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/Library/Keychains/**" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.npmrc" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.anthropic.com/*"
        },
        {
          "url": "https://api.openai.com/*"
        },
        {
          "url": "https://generativelanguage.googleapis.com/*"
        },
        {
          "url": "https://openrouter.ai/*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$APPDATA/attachments"
        },
        {
          "path": "$APPDATA/attachments/**"
        }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        {
          "path": "$APPDATA/attachments"
        },
        {
          "path": "$APPDATA/attachments/**"
        }
      ]
    }
  ]
}
