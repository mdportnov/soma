{
  "name": "soma-mcp",
  "private": true,
  "version": "0.1.0",
  "description": "Local stdio MCP server exposing the Soma health database to AI assistants",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.0"
  }
}
