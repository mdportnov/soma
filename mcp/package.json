{
  "name": "soma-mcp",
  "private": true,
  "version": "0.1.0",
  "description": "Local stdio MCP server exposing the Soma health database to AI assistants",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/soma-mcp",
    "build:sidecar": "bun build src/index.ts --compile --outfile ../src-tauri/binaries/soma-mcp-$(rustc -Vv | sed -n 's/host: //p')",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.15.0",
    "typescript": "~5.8.0"
  }
}
