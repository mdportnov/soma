{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soma",
  "version": "0.1.0",
  "identifier": "com.soma.health",
  "build": {
    "beforeDevCommand": "pnpm mcp:sidecar && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm mcp:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Soma — Personal Health Dashboard",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/soma-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
